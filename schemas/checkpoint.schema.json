{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Interview Checkpoint",
  "description": "Resumption checkpoint written by prd-interviewer after each answered question. Enables session recovery after interruption.",
  "type": "object",
  "required": ["session_id", "current_question_index", "answered_context_snapshot", "timestamp"],
  "properties": {
    "session_id": { "type": "string", "pattern": "^prd-[0-9]{8}-[0-9]{6}$" },
    "current_question_index": { "type": "integer", "minimum": 0 },
    "answered_context_snapshot": { "type": "object" },
    "timestamp": { "type": "string", "format": "date-time" }
  }
}
