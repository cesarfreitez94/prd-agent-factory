{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PRD Question Set",
  "description": "Generated by prd-planner. Consumed by prd-interviewer one question at a time (or in batches when batchable).",
  "type": "object",
  "required": ["session_id", "generated_at", "total_questions", "mode", "questions"],
  "properties": {
    "session_id":      { "type": "string", "pattern": "^prd-[0-9]{8}-[0-9]{6}$" },
    "generated_at":    { "type": "string", "format": "date-time" },
    "total_questions": { "type": "integer", "minimum": 1, "maximum": 15 },
    "mode":            { "type": "string", "enum": ["normal", "fast"], "default": "normal", "description": "Interview mode. fast reduces non-blocking questions." },
    "questions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "prd_section", "priority", "blocking", "text", "options", "status"],
        "properties": {
          "id":                   { "type": "string", "pattern": "^(Q|QD)[0-9]{1,2}$" },
          "prd_section":          { "type": "string", "enum": ["target_users","problem_statement","strategic_context","solution_scope","functional_requirements","success_metrics","constraints_risks","out_of_scope"] },
          "priority":             { "type": "integer", "minimum": 1 },
          "blocking":             { "type": "boolean" },
          "batchable":            { "type": "boolean", "default": false, "description": "If true, this question may be presented in a batch of up to batch_size questions." },
          "text":                 { "type": "string", "minLength": 10 },
          "options":              { "type": "array", "minItems": 2, "maxItems": 5, "items": { "type": "string" } },
          "free_text_if":         { "type": "array", "items": { "type": "string" } },
          "status":               { "type": "string", "enum": ["PENDING","ANSWERED","INCOMPLETE","SKIPPED"] },
          "answer":               { "type": ["string", "null"] },
          "answer_text":          { "type": ["string", "null"] },
          "congruence_attempts":  { "type": "integer", "minimum": 0, "maximum": 3 },
          "skipped_reason":       { "type": ["string", "null"] },
          "incomplete_reason":    { "type": ["string", "null"] }
        }
      }
    }
  }
}
